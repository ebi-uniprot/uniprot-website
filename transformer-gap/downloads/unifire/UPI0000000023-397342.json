{"accession":"UPI0000000023:397342","predictions":[{"evidence":["ARBA00034670"],"annotationType":"comment.function","annotationValue":"Envelope protein which is a major component of the mature virion (MV) membrane. Essential for membrane biogenesis. Is required, together with OPG144, to form bona fide crescents, which can progress to form the immature virion (IV) membrane. OPG140 and OPG144 form a lattice that is stabilized by disulfide bonds and serves as an anchor within the viral membrane to which several other proteins important in virion structure and morphogenesis attach"},{"evidence":["ARBA00034759"],"annotationType":"comment.similarity","annotationValue":"Belongs to the orthopoxvirus OPG140 family"},{"evidence":["ARBA00004370"],"annotationType":"comment.subcellular_location","annotationValue":"Membrane"},{"evidence":["ARBA00004141"],"annotationType":"comment.subcellular_location","annotationValue":"Membrane; Multi-pass membrane protein"},{"evidence":["ARBA00004328"],"annotationType":"comment.subcellular_location","annotationValue":"Virion"},{"evidence":["ARBA00004182"],"annotationType":"comment.subcellular_location","annotationValue":"Virion membrane"},{"evidence":["ARBA00004385"],"annotationType":"comment.subcellular_location","annotationValue":"Virion membrane; Multi-pass membrane protein"},{"evidence":["ARBA00034792"],"annotationType":"comment.subunit","annotationValue":"Homodimer; disulfide-linked. Interacts with OPG144"},{"evidence":["ARBA00023157"],"annotationType":"keyword","annotationValue":"Disulfide bond"},{"evidence":["ARBA00023136"],"annotationType":"keyword","annotationValue":"Membrane"},{"evidence":["ARBA00022553"],"annotationType":"keyword","annotationValue":"Phosphoprotein"},{"evidence":["ARBA00022692"],"annotationType":"keyword","annotationValue":"Transmembrane"},{"evidence":["ARBA00022989"],"annotationType":"keyword","annotationValue":"Transmembrane helix"},{"evidence":["ARBA00022879"],"annotationType":"keyword","annotationValue":"Viral env