{"entryType":"AA","primaryAccession":"UPI0000000023-397342","uniProtkbId":null,"annotationScore":0.0,"proteinDescription":{"recommendedName":{"fullName":{"evidences":[{"evidenceCode":"ECO:0000256","source":"ARBA","id":"ARBA00034841"}],"value":"Virion membrane protein OPG140"}}},"comments":[{"texts":[{"evidences":[{"evidenceCode":"ECO:0000256","source":"ARBA","id":"ARBA00034670"}],"value":"Envelope protein which is a major component of the mature virion (MV) membrane. Essential for membrane biogenesis. Is required, together with OPG144, to form bona fide crescents, which can progress to form the immature virion (IV) membrane. OPG140 and OPG144 form a lattice that is stabilized by disulfide bonds and serves as an anchor within the viral membrane to which several other proteins important in virion structure and morphogenesis attach"}],"commentType":"FUNCTION"},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000256","source":"ARBA","id":"ARBA00034792"}],"value":"Homodimer; disulfide-linked. Interacts with OPG144"}],"commentType":"SUBUNIT"},{"commentType":"SUBCELLULAR LOCATION","subcellularLocations":[{"location":{"evidences":[{"evidenceCode":"ECO:0000256","source":"ARBA","id":"ARBA00004385"}],"value":"Virion membrane","id":"SL-0275"},"topology":{"evidences":[{"evidenceCode":"ECO:0000256","source":"ARBA","id":"ARBA00004385"}],"value":"Multi-pass membrane protein","id":"SL-9909"}}]},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000256","source":"ARBA","id":"ARBA00034759"}],"value":"Belongs to the orthopoxvirus OPG140 family"}],"commentType":"SIMILARITY"}],"keywords":[{"evidences":[{"evidenceCode":"ECO:0000256","source":"ARBA","id":"ARBA00023157"}],"id":"KW-1015","category":"PTM","name":"Disulfide bond"},{"evidences":[{"evidenceCode":"ECO:0000256","source":"ARBA","id":"ARBA00023136"}],"id":"KW-0472","category":"Cellular component","name":"Membrane"},{"evidences":[{"evidenceCode":"ECO:0000256","source":"ARBA","id":"ARBA00022553"}],"id":"KW-0597","category":"PTM","name":"Phosp