{
  "compilerOptions": {
    // Target latest version of ECMAScript.
    "target": "esnext",
    // Mirror the bundler's resolution: honors `exports` maps when present,
    // falls back to `main`/index lookup when absent.
    "moduleResolution": "bundler",
    // Process & infer types from .js files.
    "allowJs": true,
    // Don't emit; allow Babel to transform files.
    "noEmit": true,
    // Enable strictest settings like strictNullChecks & noImplicitAny.
    "strict": true,
    // Disallow features that require cross-file information for emit.
    "isolatedModules": true,
    // Import non-ES modules as default imports.
    "resolveJsonModule": true,
    "removeComments": true,
    "esModuleInterop": true,
    "module": "esnext",
    "jsx": "react-jsx",
    "types": ["jest", "node", "@testing-library/jest-dom", "gtag.js"],
    "lib": ["ESNext", "ES2020", "WebWorker", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "plugins": [
      // TypeScript language service plugin for CSS Modules.
      // NOTE: this will only be useful for an IDE, but won't be enforced
      {
        "name": "typescript-plugin-css-modules"
      }
    ],
    "paths": {
      "react": ["./node_modules/@types/react"],
      // franklin-sites and protvista-uniprot publish types but their `exports`
      // maps lack a "types" condition, so `bundler` resolution can't find them.
      // Alias to the declaration files until those packages add the condition.
      "franklin-sites": [
        "./node_modules/franklin-sites/dist/types/components/index.d.ts"
      ],
      "franklin-sites/dist/types/*": [
        "./node_modules/franklin-sites/dist/types/*"
      ],
      "protvista-uniprot": [
        "./node_modules/protvista-uniprot/dist/types/index.d.ts"
      ]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
